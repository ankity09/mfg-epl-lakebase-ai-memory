# Make a copy of this to set environment variables for local development
# cp .env.example .env

# Databricks authentication
DATABRICKS_CONFIG_PROFILE=stable-trvrmk
# DATABRICKS_HOST=https://fevm-serverless-stable-trvrmk.cloud.databricks.com
# DATABRICKS_TOKEN=dapi....

# MLflow experiment for tracing
MLFLOW_EXPERIMENT_ID=4015809073496861

# Lakebase autoscaling instance
LAKEBASE_AUTOSCALING_PROJECT=lakebase-mfg-epl
LAKEBASE_AUTOSCALING_BRANCH=production

# MaintBot configuration
DATABASE_NAME=mfg_maintenance_db
LLM_ENDPOINT=databricks-claude-sonnet-4-5
EMBEDDING_ENDPOINT=databricks-gte-large-en

# Compaction settings
COMPACT_STRATEGY=summarize
COMPACT_THRESHOLD=0.8
COMPACT_KEEP_TURNS=5

# Memory backend: "pgvector" (default) or "databricks_vs"
MEMORY_BACKEND=pgvector

# Databricks Vector Search config (only needed if MEMORY_BACKEND=databricks_vs)
VS_ENDPOINT_NAME=maint-bot-vs-endpoint
VS_CATALOG=ankit_yadav
VS_SCHEMA=maint_bot

# App ports
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
